{
  "mcpServers": {
    "pyeye": {
      "args": [
        "run",
        "--project",
        "${CLAUDE_PLUGIN_ROOT}",
        "--no-sync",
        "--frozen",
        "python",
        "-m",
        "pyeye.mcp"
      ],
      "command": "uv",
      "env": {
        "UV_PROJECT_ENVIRONMENT": "${CLAUDE_PLUGIN_DATA}/.venv"
      }
    }
  }
}

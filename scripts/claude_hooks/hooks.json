{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/GitHub/pyeye-mcp/scripts/claude_hooks/track_mcp_success.py",
            "type": "command"
          }
        ],
        "matcher": "mcp__pyeye__.*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 ~/GitHub/pyeye-mcp/scripts/claude_hooks/track_mcp_call.py",
            "type": "command"
          }
        ],
        "matcher": "mcp__pyeye__.*"
      },
      {
        "hooks": [
          {
            "command": "python3 ~/GitHub/pyeye-mcp/scripts/claude_hooks/detect_grep_usage.py",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "echo \"$(date +%Y-%m-%d_%H:%M:%S),grep_tool,direct\" >> ~/.claude/mcp_monitoring/grep_usage.csv",
            "type": "command"
          }
        ],
        "matcher": "Grep"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "python3 ~/GitHub/pyeye-mcp/scripts/claude_hooks/session_tracker.py end",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python3 ~/GitHub/pyeye-mcp/scripts/claude_hooks/session_tracker.py start",
            "type": "command"
          }
        ]
      }
    ]
  }
}
